---
import TagPill from "@components/TagPill.astro";

import { TAGS } from "@utils/constants";

const { cover, date, slug, tags, title } = Astro.props;
---

<article class="card-read">
  <a aria-label={title} class="card-link" href={slug}>
    <div class="card-info">
      <div>
        {
          tags && tags.length > 0 && (
            <div class="card-info-tags">
              {tags.map((tag: keyof typeof TAGS) => (
                <TagPill class="card-info-tag" data-ui-tag={tag}>
                  {TAGS[tag].text}
                </TagPill>
              ))}
            </div>
          )
        }
        <h3 class="card-info-title">{title}</h3>
        <p class="card-info-date">{date}</p>
      </div>
    </div>
    <figure aria-hidden="true" class="card-figure">
      <img loading="lazy" src={cover} alt="" />
    </figure>
  </a>
</article>

<style lang="scss" scoped>
  .card-figure {
    grid-area: card;
    height: 100%;
    position: relative;
    z-index: 0;
    overflow: hidden;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: scale 0.3s ease;
    }
  }

  .card-info {
    --tag-pill-padding-block: 4px;
    --tag-pill-padding-inline: 8px;
    grid-area: card;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-block: 16px 20px;
    padding-inline: 12px;
    z-index: 1;
    color: var(--color-yellow-grey-100);
    background: linear-gradient(
      180deg,
      rgba(158, 148, 250, 0) 32%,
      rgba(31, 31, 31, 0.5) 64%
    );

    @include container-tablet {
      --tag-pill-padding-block: 6px;
      --tag-pill-padding-inline: 12px;
      padding-block: 16px 24px;
      padding-inline: 16px;
    }
  }

  .card-info-date {
    font-size: 0.875rem;
    font-weight: 700;
    text-shadow:
      2px 2px 0px var(--color-grey-dark-200),
      -1px -1px 0 var(--color-grey-dark-200),
      1px -1px 0 var(--color-grey-dark-200),
      -1px 1px 0 var(--color-grey-dark-200),
      1px 1px 0 var(--color-grey-dark-200);
  }

  .card-info-tags {
    --tag-border: 2px solid var(--color-grey-dark-200);
    --tag-pill-font-size: 0.625rem;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-block-end: 12px;

    @include container-tablet {
      --tag-border: 4px solid var(--color-grey-dark-200);
      --tag-pill-font-size: 0.875rem;
    }
  }

  .card-info-tag {
    --tag-pill-padding-inline: 6px;
    --tag-pill-background: var(--color-orange-100);

    @include container-tablet {
      --tag-pill-padding-inline: 8px;
    }

    &[data-ui-tag="destaque-da-serie"] {
      --tag-pill-background: var(--color-blue-100);
    }
  }

  .card-info-title {
    font-size: 1rem;
    text-shadow:
      3px 3px 0px var(--color-grey-dark-200),
      -1px -1px 0 var(--color-grey-dark-200),
      1px -1px 0 var(--color-grey-dark-200),
      -1px 1px 0 var(--color-grey-dark-200),
      1px 1px 0 var(--color-grey-dark-200);

    @include container-tablet {
      font-size: 1.5rem;
    }

    @include container-desktop {
      font-size: 1.7rem;
    }

    &:not(:last-child) {
      margin-block-end: 4px;
    }
  }

  .card-link {
    display: grid;
    grid-template-areas: "card";
    height: 100%;
    text-decoration: none;
  }

  .card-read {
    aspect-ratio: 3 / 4.4;
    border: 2px solid var(--color-grey-dark-200);
    box-shadow: 0px 0px 0px var(--color-grey-dark-200);
    overflow: hidden;
    transform: translate(0px, 0px);
    transition:
      transform 0.25s ease-in-out,
      box-shadow 0.25s ease-in-out;

    @media (hover: hover) {
      &:hover {
        img {
          scale: 1.02;
        }
      }
    }
  }
</style>
