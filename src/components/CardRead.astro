---
import RatingBar from "@components/RatingBar.astro";
import TagPill from "@components/TagPill.astro";

const { cover, date, rating, slug, title } = Astro.props;
---

<article class="card-read">
  <a aria-label={title} class="card-link" href={slug}>
    <div class="card-info">
      <div>
        <TagPill class="card-info-rating" tag="div">
          <RatingBar rating={rating} />
        </TagPill>
        <h3 class="card-info-title">{title}</h3>
        <p class="card-info-date">{date}</p>
      </div>
    </div>
    <figure aria-hidden="true" class="card-figure">
      <img loading="lazy" src={`/images/covers/${cover}`} alt="" />
    </figure>
  </a>
</article>

<style lang="scss" scoped>
  .card-figure {
    grid-area: card;
    height: 100%;
    position: relative;
    z-index: 0;
    overflow: hidden;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: scale 0.3s ease;
    }
  }

  .card-info {
    --tag-pill-padding-block: 4px;
    --tag-pill-padding-inline: 8px;
    grid-area: card;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-block: 16px 24px;
    padding-inline: 16px;
    z-index: 1;
    color: var(--color-yellow-grey-100);
    background: linear-gradient(
      180deg,
      rgba(158, 148, 250, 0) 32%,
      rgba(94, 88, 148, 0.5) 64%
    );

    @include container-tablet {
      --tag-pill-padding-block: 6px;
      --tag-pill-padding-inline: 12px;
      padding-block: 16px 24px;
      padding-inline: 16px;
    }
  }

  .card-info-date {
    font-size: 0.875rem;
    font-weight: 700;
    text-shadow:
      2px 2px 0px var(--color-grey-dark-200),
      -1px -1px 0 var(--color-grey-dark-200),
      1px -1px 0 var(--color-grey-dark-200),
      -1px 1px 0 var(--color-grey-dark-200),
      1px 1px 0 var(--color-grey-dark-200);
  }

  .card-info-rating {
    --rating-icon-size: 22px;
    --rating-color-empty: var(--color-purple-200);
    --rating-color-filled: var(--color-grey-light-100);
    --tag-pill-padding-inline: 8px;
    --tag-pill-background: var(--color-orange-100);
    --tag-pill-box-shadow: none;
    margin-block-end: 12px;
  }

  .card-info-title {
    font-size: 1.5rem;
    text-shadow:
      3px 3px 0px var(--color-grey-dark-200),
      -1px -1px 0 var(--color-grey-dark-200),
      1px -1px 0 var(--color-grey-dark-200),
      -1px 1px 0 var(--color-grey-dark-200),
      1px 1px 0 var(--color-grey-dark-200);

    &:not(:last-child) {
      margin-block-end: 4px;
    }
  }

  .card-link {
    display: grid;
    grid-template-areas: "card";
    height: 100%;
    text-decoration: none;
  }

  .card-read {
    aspect-ratio: 3 / 3.8;
    border: 2px solid var(--color-grey-dark-200);
    box-shadow: 0px 0px 0px var(--color-grey-dark-200);
    transform: translate(0px, 0px);
    transition:
      transform 0.25s ease-in-out,
      box-shadow 0.25s ease-in-out;

    @include container-desktop {
      aspect-ratio: 3 / 4.4;
    }

    @media (hover: hover) {
      &:hover {
        transform: translate(-1px, -1px);
        box-shadow: 4px 3px 0px var(--color-grey-dark-200);
      }
    }
  }
</style>
