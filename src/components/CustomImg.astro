---
interface Props {
  alt?: string;
  caption: string;
  size?: "default" | "small";
  src: string;
}

const { alt, caption, size, src } = Astro.props;
---

<figure class="custom-img" data-ui-size={size || "default"}>
  <img src={src} alt={alt} />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style lang="scss">
  .custom-img {
    max-inline-size: 735px;
    margin-inline: auto;

    &[data-ui-size="small"] {
      max-inline-size: 410px;
    }

    figcaption {
      padding-block-start: 8px;
      font-size: 0.875rem;
      font-style: italic;
      font-weight: 500;
      color: var(--color-grey-light-1100);
      text-align: right;
    }

    img {
      width: 100%;
      border: 2px solid var(--color-grey-dark-200);
      border-radius: 2px;
    }

    &:not(:last-child) {
      margin-block-end: 40px;

      @include container-desktop {
        margin-block-end: 64px;
      }
    }
  }
</style>
