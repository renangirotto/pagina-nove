---
import CustomIcon from "@components/CustomIcon.astro";
import DialogDrawer from "@components/DialogDrawer.astro";
import LayoutContainer from "@components/LayoutContainer.astro";
import LogoSvg from "@components/LogoSvg.astro";

import { NAV_ITEMS, ROUTES } from "@utils/constants";

const { pathname } = Astro.url;
---

<header class="header">
  <LayoutContainer class="header-container">
    <a class="header-logo" href={ROUTES.home}>
      <LogoSvg />
    </a>

    <nav class="nav" data-ui-decive="mobile">
      <button class="nav-button" id="nav-button-mobile">
        <CustomIcon name="menu" />
      </button>

      <DialogDrawer id="dialog-nav" class="nav-dialog" title="Outras páginas">
        <ul class="nav-list">
          {
            NAV_ITEMS.map((item) =>
              item.children ? (
                <li class="nav-item-dropdown">
                  <details class="nav-dropdown">
                    <summary
                      class="nav-link"
                      data-ui-nav-link-active={
                        item.children.some((c) => c.href === pathname) || null
                      }
                    >
                      {item.label}
                    </summary>
                    <ul class="nav-dropdown-list">
                      {item.children.map((child) => (
                        <li>
                          <a
                            class="nav-link nav-link-mobile"
                            data-ui-nav-link-active={
                              child.href === pathname || null
                            }
                            data-ui-nav-link-target="children"
                            href={child.href}
                            target={child.target || "_self"}
                          >
                            {child.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                </li>
              ) : (
                <li>
                  <a
                    class="nav-link nav-link-mobile"
                    data-ui-nav-link-active={item.href === pathname || null}
                    href={item.href}
                    target={item.target || `_self`}
                  >
                    {item.label}
                  </a>
                </li>
              ),
            )
          }
        </ul>
      </DialogDrawer>
    </nav>

    <nav class="nav" data-ui-decive="desktop">
      <ul class="nav-list">
        {
          NAV_ITEMS.map((item) =>
            item.children ? (
              <li class="nav-item-dropdown">
                <details class="nav-dropdown">
                  <summary
                    class="nav-link"
                    data-ui-nav-link-active={
                      item.children.some((c) => c.href === pathname) || null
                    }
                  >
                    {item.label}
                  </summary>
                  <ul class="nav-dropdown-list">
                    {item.children.map((child) => (
                      <li>
                        <a
                          class="nav-link"
                          data-ui-nav-link-active={
                            child.href === pathname || null
                          }
                          data-ui-nav-link-target="children"
                          href={child.href}
                          target={child.target || "_self"}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            ) : (
              <li>
                <a
                  class="nav-link"
                  data-ui-nav-link-active={item.href === pathname || null}
                  href={item.href}
                  target={item.target || `_self`}
                >
                  {item.label}
                </a>
              </li>
            ),
          )
        }
      </ul>
    </nav>
  </LayoutContainer>
</header>

<script>
  const buttonNavMobile = document.getElementById("nav-button-mobile");
  const dialog = document.getElementById("dialog-nav");

  buttonNavMobile?.addEventListener("click", () => {
    (dialog as HTMLDialogElement)?.showModal();
  });

  const mobileLinks = document.querySelectorAll(".nav-link-mobile");

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      (dialog as HTMLDialogElement)?.close();
    });
  });

  document.addEventListener("click", (e) => {
    const target = e.target as Element;
    document.querySelectorAll(".nav-dropdown[open]").forEach((dropdown) => {
      if (!dropdown.contains(target)) {
        (dropdown as HTMLDetailsElement).open = false;
      }
    });
  });
</script>

<style lang="scss">
  .header {
    padding-inline: 16px;
  }

  .header-container {
    display: grid;
    grid-template-columns: 96px 1fr;
    grid-template-rows: auto;
    gap: 0px 16px;
    grid-template-areas: "logo nav";
    align-items: center;
    width: 100%;
    padding-block: 24px 24px;
    padding-inline: 8px;
    border-block-end: 1px solid var(--color-grey-light-100);

    @include container-desktop {
      padding-block: 32px 32px;
      padding-inline: 0px;
    }
  }

  .header-logo {
    grid-area: logo;
  }

  .nav {
    grid-area: nav;
    justify-self: end;
    font-size: 20px;

    &[data-ui-decive="mobile"] {
      @include container-desktop {
        display: none;
      }
    }

    &[data-ui-decive="desktop"] {
      display: none;

      @include container-desktop {
        display: block;
      }
    }
  }

  .nav-button {
    --icon-size: 24px;
    --icon-size: 24px;
    --icon-color-light: var(--color-grey-dark-100);

    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    padding-block: 12px;
    padding-inline: 12px;
    border: 3px solid var(--color-grey-dark-200);
    background: var(--color-purple-100);
    box-shadow: 2px 2px 0px var(--color-grey-dark-200);
  }

  .nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    padding-inline-start: 0;

    @include container-desktop {
      flex-direction: row;
    }

    li {
      width: 100%;

      @include container-desktop {
        width: auto;
      }
    }
  }

  .nav-item-dropdown {
    position: relative;
  }

  .nav-dropdown {
    summary {
      list-style: none;
      cursor: pointer;

      &::-webkit-details-marker {
        display: none;
      }
    }
  }

  .nav-dropdown-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-inline-start: 0;
    margin-block-start: 8px;

    @include container-desktop {
      position: absolute;
      top: calc(100% + 4px);
      right: 0;
      z-index: 10;
      gap: 0;
      margin-block-start: 0;
      min-width: 120px;
      box-shadow: 0px 4px 7px 0px rgba(0, 0, 0, 0.1);
      background: var(--color-yellow-grey-100);
    }
  }

  .nav-link {
    --icon-size: 24px;
    --icon-color-dark: var(--color-grey-light-200);
    --icon-color-light: var(--color-grey-light-100);

    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    padding-block: 12px;
    padding-inline: 24px;
    border: 3px solid var(--nav-link-border-color, transparent);
    font-size: 1.25rem;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    transition: all 0.25s ease;

    @include container-desktop {
      --icon-size: 18px;
      padding-block: 8px;
      padding-inline: 12px;
      font-size: 0.875rem;
      gap: 6px;
      text-transform: uppercase;
    }

    &:hover,
    &:focus-within {
      --nav-link-border-color: var(--color-grey-light-200);
      background: var(--color-grey-light-100);

      @include container-desktop {
        --icon-color-dark: var(--color-purple-200);
        --icon-color-light: var(--color-purple-100);
      }
    }

    &[data-ui-nav-link-target="children"] {
      &[data-ui-nav-link-active="true"] {
        --nav-link-border-color: var(--color-purple-100);
        background: var(--color-purple-50);
      }
    }

    &[data-ui-nav-link-active="true"] {
      --icon-color-dark: var(--color-purple-200);
      --icon-color-light: var(--color-purple-100);
      --nav-link-border-color: var(--color-grey-dark-200);
      background: var(--color-purple-100);

      &:not([data-ui-nav-link-target="children"]) {
        box-shadow: 2px 2px 0px var(--color-grey-dark-200);
      }
    }
  }
</style>
