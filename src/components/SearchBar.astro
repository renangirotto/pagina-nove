---
import { ROUTES } from "@utils/constants";

interface SearchItem {
  title: string;
  artists: string[];
  slug: string;
  series?: string;
  seriesSlug?: string;
}

interface Props {
  searchData: SearchItem[];
  class?: string;
}

const { searchData, class: className } = Astro.props;
---

<div class:list={["search-bar", className]}>
  <form class="search-form" id="search-bar-form" action={ROUTES.search} method="get">
    <div class="search-input-wrapper">
      <input
        type="search"
        name="busca"
        id="search-bar-input"
        class="search-input"
        placeholder="Buscar por título ou artista..."
        autocomplete="off"
        aria-label="Buscar leituras"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-controls="search-bar-suggestions"
        aria-autocomplete="list"
      />
      <button type="submit" class="search-submit" aria-label="Buscar">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="7.5" cy="7.5" r="6" stroke="currentColor" stroke-width="2.5" />
          <path d="M12 12L16 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>
    <ul
      id="search-bar-suggestions"
      class="search-suggestions"
      role="listbox"
      aria-label="Sugestões de busca"
      hidden
    >
    </ul>
  </form>
</div>

<script define:vars={{ searchData }}>
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("search-bar-form");
    const input = document.getElementById("search-bar-input");
    const suggestionsList = document.getElementById("search-bar-suggestions");

    if (!form || !input || !suggestionsList) return;

    let activeIndex = -1;

    function normalize(text) {
      return text
        .toLowerCase()
        .normalize("NFD")
        .replace(/[̀-ͯ]/g, "");
    }

    const normalizedData = searchData.map((item) => ({
      ...item,
      _norm: normalize(item.title + " " + item.artists.join(" ")),
    }));

    // Pre-compute per series: total issue count and unique artists
    const seriesInfo = new Map();
    searchData.forEach((item) => {
      if (item.seriesSlug) {
        if (!seriesInfo.has(item.seriesSlug)) {
          seriesInfo.set(item.seriesSlug, { total: 0, artists: new Set() });
        }
        const info = seriesInfo.get(item.seriesSlug);
        info.total += 1;
        item.artists.forEach((a) => info.artists.add(a));
      }
    });

    function getMatches(query) {
      const q = normalize(query);
      const matching = normalizedData.filter((item) => item._norm.includes(q));

      const seriesGroups = new Map();
      const standalone = [];

      matching.forEach((item) => {
        if (item.seriesSlug) {
          if (!seriesGroups.has(item.seriesSlug)) {
            const info = seriesInfo.get(item.seriesSlug);
            const total = info?.total ?? 1;
            const singleArtist = info?.artists.size === 1 ? [...info.artists][0] : null;
            const subtitle = singleArtist
              ? `${singleArtist} — Coleção com ${total} volume${total !== 1 ? "s" : ""}`
              : `Coleção com ${total} volume${total !== 1 ? "s" : ""}`;
            seriesGroups.set(item.seriesSlug, {
              title: item.series,
              slug: `/colecoes/${item.seriesSlug}/`,
              subtitle,
              isSeries: true,
            });
          }
        } else {
          standalone.push(item);
        }
      });

      return [...seriesGroups.values(), ...standalone].slice(0, 8);
    }

    function closeSuggestions() {
      suggestionsList.hidden = true;
      input.setAttribute("aria-expanded", "false");
      activeIndex = -1;
      suggestionsList
        .querySelectorAll("[aria-selected='true']")
        .forEach((el) => el.setAttribute("aria-selected", "false"));
    }

    function setActiveIndex(items, index) {
      items.forEach((item, i) => {
        const isActive = i === index;
        item.setAttribute("aria-selected", String(isActive));
        item.classList.toggle("search-suggestion--active", isActive);
      });
      activeIndex = index;
    }

    function renderSuggestions(matches) {
      activeIndex = -1;
      if (!matches.length) {
        closeSuggestions();
        return;
      }

      suggestionsList.innerHTML = matches
        .map((item) => {
          const subtitle = item.isSeries ? item.subtitle : item.artists.join(", ");
          return `<li class="search-suggestion" role="option" aria-selected="false" data-slug="${item.slug}">
            <span class="search-suggestion-title">${item.title}</span>
            <span class="search-suggestion-artists">${subtitle}</span>
          </li>`;
        })
        .join("");

      suggestionsList.hidden = false;
      input.setAttribute("aria-expanded", "true");
    }

    // Pre-fill input on /busca/ page
    const urlParams = new URLSearchParams(window.location.search);
    const urlQuery = urlParams.get("busca");
    if (urlQuery) {
      input.value = urlQuery;
    }

    form.addEventListener("submit", (e) => {
      if (!input.value.trim()) {
        e.preventDefault();
      }
    });

    input.addEventListener("input", () => {
      const query = input.value.trim();
      if (query.length < 3) {
        closeSuggestions();
        return;
      }
      renderSuggestions(getMatches(query));
    });

    input.addEventListener("keydown", (e) => {
      const items = [...suggestionsList.querySelectorAll("[role='option']")];
      if (!items.length || suggestionsList.hidden) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActiveIndex(items, (activeIndex + 1) % items.length);
        return;
      }

      if (e.key === "ArrowUp") {
        e.preventDefault();
        setActiveIndex(items, activeIndex <= 0 ? items.length - 1 : activeIndex - 1);
        return;
      }

      if (e.key === "Enter" && activeIndex >= 0) {
        e.preventDefault();
        const slug = items[activeIndex]?.dataset.slug;
        if (slug) window.location.href = slug;
        return;
      }

      if (e.key === "Escape") {
        closeSuggestions();
      }
    });

    suggestionsList.addEventListener("click", (e) => {
      const item = e.target.closest("[data-slug]");
      if (item?.dataset.slug) {
        window.location.href = item.dataset.slug;
      }
    });

    document.addEventListener("click", (e) => {
      if (!form.contains(e.target)) {
        closeSuggestions();
      }
    });
  });
</script>

<style lang="scss">
  .search-bar {
    position: relative;
    width: 100%;

    &:not(:last-child) {
      margin-block-end: 40px;
    }
  }

  .search-form {
    position: relative;
  }

  .search-input-wrapper {
    display: flex;
    align-items: stretch;
    min-height: clamp(56px, 13vw, 64px);
    border: 3px solid var(--color-grey-dark-200);
    box-shadow: 3px 3px 0px var(--color-grey-dark-200);
    background: var(--color-yellow-grey-100);

    &:focus-within {
      outline: 2px solid var(--color-purple-100);
      outline-offset: 2px;
    }
  }

  .search-input {
    flex: 1;
    min-width: 0;
    padding-block: 10px;
    padding-inline: 20px;
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-grey-dark-100);
    outline: none;

    &::placeholder {
      color: var(--color-grey-light-1100);
      font-weight: 400;
    }

    &::-webkit-search-cancel-button {
      cursor: pointer;
    }

    @include container-tablet {
      font-size: 1.0625rem;
    }
  }

  .search-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: clamp(56px, 13vw, 64px);
    padding: 0;
    border: none;
    border-inline-start: 3px solid var(--color-grey-dark-200);
    background: var(--color-purple-100);
    color: var(--color-grey-dark-100);
    cursor: pointer;
    transition: background 0.2s ease;

    &:hover {
      background: var(--color-purple-200);
      color: var(--color-yellow-grey-100);
    }
  }

  .search-suggestions {
    position: absolute;
    top: calc(100% + 2px);
    left: 0;
    right: 0;
    z-index: 20;
    list-style: none;
    padding: 0;
    margin: 0;
    border: 3px solid var(--color-grey-dark-200);
    box-shadow: 3px 3px 0px var(--color-grey-dark-200);
    background: var(--color-yellow-grey-100);
    max-height: 360px;
    overflow-y: auto;
  }

  :global(.search-suggestion) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-block: 10px;
    padding-inline: 14px;
    cursor: pointer;
    border-block-end: 1px solid var(--color-grey-light-100);
    transition: background 0.15s ease;

    &:last-child {
      border-block-end: none;
    }

    &:hover,
    &.search-suggestion--active {
      background: var(--color-purple-50);
    }
  }

  :global(.search-suggestion-title) {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-grey-dark-100);
  }

  :global(.search-suggestion-artists) {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-grey-light-1100);
  }
</style>
