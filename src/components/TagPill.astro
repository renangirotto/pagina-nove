---
const { class: className, tag, ...rest } = Astro.props;

const CustomTag = tag || "p";
---

<CustomTag :is="is" class:list={["tag-pill", className]} {...rest}>
  <slot />
</CustomTag>

<style lang="scss">
  .tag-pill {
    width: fit-content;
    padding-block: var(--tag-pill-padding-block, 4px);
    padding-inline: var(--tag-pill-padding-inline, 8px);
    border: 4px solid var(--tag-border, var(--color-grey-dark-200));
    // border-radius: var(--tag-pull-border-radius, 32px);
    font-size: var(--tag-pill-font-size, 0.875rem);
    font-weight: 900;
    color: var(--tag-pill-color, var(--color-grey-dark-200));
    text-box-trim: trim-both;
    text-transform: uppercase;
    background: var(--tag-pill-background, var(--color-purple-100));
    box-shadow: var(--tag-pill-box-shadow, 4px 2px 0px 0px rgba(#1e1e1e, 1));

    &:last-child {
      align-self: center;
    }
  }
</style>
