---
import "@fontsource-variable/outfit";
import "@fontsource-variable/raleway";

import "@styles/reset.css";
import "@styles/colors.css";
import "@styles/typography.css";

import HeaderNavbar from "@components/HeaderNavbar.astro";
import { ClientRouter } from "astro:transitions";

const { title } = Astro.props;

const isProd = import.meta.env.PROD;

const PageTitle = title
  ? `${title} | Página Nove`
  : "Página Nove | Quadinhos e textos mal escritos.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{PageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <HeaderNavbar />
    <main class="layout-main">
      <slot />
    </main>
  </body><!-- <script is:inline src="/scripts/newrelic.js"></script> -->{
    isProd && (
      <script
        is:inline
        defer
        src="https://cloud.umami.is/script.js"
        data-website-id="7d0306c1-6aa3-49b8-9d4b-a782dec84ba5"
      />
    )
  }
</html>

<style lang="scss">
  .layout-main {
    padding-block: 44px 64px;
    padding-inline: 16px;
    position: relative;
    overflow: hidden;

    @include container-desktop {
      padding-block: 44px 88px;
    }
  }
</style>
