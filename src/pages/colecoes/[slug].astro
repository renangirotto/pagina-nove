---
import { getCollection } from "astro:content";

import Breadcrumb from "@components/Breadcrumb.astro";
import CardRead from "@components/CardRead.astro";
import GridRead from "@components/GridRead.astro";
import LayoutContainer from "@components/LayoutContainer.astro";
import TextPage from "@components/TextPage.astro";
import TitlePage from "@components/TitlePage.astro";

import Layout from "@layouts/Layout.astro";

import formatDate from "@utils/format-date";
import formatEntryToCardRead from "@utils/format-entry-to-card-read";
import { ROUTES } from "@utils/constants";
import { slugify } from "@utils/slugify";

export async function getStaticPaths() {
  const allReadings = await getCollection("readings");
  const allSeries = await getCollection("series");

  const grouped = allReadings.reduce(
    (acc, reading) => {
      const { series } = reading.data;
      if (!series) return acc;
      if (!acc[series]) acc[series] = [];
      acc[series].push(reading);
      return acc;
    },
    {} as Record<string, typeof allReadings>,
  );

  return Object.entries(grouped).map(([name, readings]) => {
    const seriesEntry = allSeries.find((s) => s.data.name === name);
    return {
      params: { slug: slugify(name) },
      props: {
        title: name,
        isFinished: seriesEntry?.data.isFinished ?? false,
        readings: readings.sort((a, b) => {
          const dateDiff = b.data.date.getTime() - a.data.date.getTime();
          if (dateDiff !== 0) return dateDiff;
          return (b.data.seriesIssue ?? 0) - (a.data.seriesIssue ?? 0);
        }),
      },
    };
  });
}

const { title, readings, isFinished } = Astro.props;

const startDate = formatDate(readings[readings.length - 1].data.date);
const finishedDate = formatDate(readings[0].data.date);

const breadcrumbs = [
  { href: ROUTES.collections, text: "Todas as Coleções" },
  { href: null, text: title },
];
---

<Layout title={title}>
  <section>
    <LayoutContainer>
      <Breadcrumb items={breadcrumbs} />
      <TitlePage>{title}</TitlePage>
      {
        isFinished ? (
          <TextPage>
            Comecei com a leitura desta coleção em <strong>{startDate}</strong>{" "}
            e finalizei em <strong>{finishedDate}</strong>.
          </TextPage>
        ) : (
          <TextPage>
            Comecei com a leitura desta coleção em <strong>{startDate}</strong>{" "}
            e é uma coleção que ainda não finalizei.
          </TextPage>
        )
      }

      <GridRead>
        {
          readings.map((reading) => (
            <CardRead {...formatEntryToCardRead(reading)} />
          ))
        }
      </GridRead>
    </LayoutContainer>
  </section>
</Layout>
