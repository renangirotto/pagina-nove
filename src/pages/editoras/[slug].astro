---
import { getCollection } from "astro:content";

import Breadcrumb from "@components/Breadcrumb.astro";
import CardCollection from "@components/CardCollection.astro";
import CardRead from "@components/CardRead.astro";
import GridRead from "@components/GridRead.astro";
import LayoutContainer from "@components/LayoutContainer.astro";
import TextPage from "@components/TextPage.astro";
import TitlePage from "@components/TitlePage.astro";

import Layout from "@layouts/Layout.astro";

import formatEntryToCardRead from "@utils/format-entry-to-card-read";
import { ROUTES } from "@utils/constants";
import { getCoverPath } from "@utils/get-cover-path";
import { slugify } from "@utils/slugify";

export async function getStaticPaths() {
  const allPublishers = await getCollection("publishers");
  const allReadings = await getCollection("readings");
  const allSeries = await getCollection("series");

  return allPublishers.map((publisher) => ({
    params: { slug: publisher.id },
    props: {
      name: publisher.data.name,
      description: publisher.data.description,
      logo: publisher.data.logo
        ? `/images/publishers/${publisher.data.logo}`
        : undefined,
      readings: allReadings.filter(
        (r) => r.data.publisher === publisher.data.name,
      ),
      seriesFinished: Object.fromEntries(
        allSeries.map((s) => [s.data.name, s.data.isFinished]),
      ),
    },
  }));
}

const { name, description, logo, readings } = Astro.props;

// Group series readings; pass singles through
const seriesMap = new Map<string, typeof readings>();
for (const reading of readings) {
  const series = reading.data.series;
  if (series) {
    if (!seriesMap.has(series)) seriesMap.set(series, []);
    seriesMap.get(series)!.push(reading);
  }
}

type SingleItem = {
  type: "single";
  cover: string;
  date: string;
  sortDate: number;
  slug: string;
  tags?: string[];
  title: string;
};

type SeriesItem = {
  type: "series";
  cover: string;
  finished?: boolean;
  publisher?: string;
  sortDate: number;
  slug: string;
  tags?: string[];
  title: string;
  volumes: number;
};

type Item = SingleItem | SeriesItem;

const items: Item[] = [];

for (const reading of readings) {
  if (!reading.data.series) {
    const card = formatEntryToCardRead(reading);
    items.push({
      type: "single",
      ...card,
      sortDate: reading.data.date.getTime(),
      tags: [...(card.tags ?? [])],
    });
  }
}

for (const [seriesName, seriesReadings] of seriesMap) {
  const firstIssue = [...seriesReadings].sort((a, b) => {
    const byIssue = (a.data.seriesIssue ?? 0) - (b.data.seriesIssue ?? 0);
    return byIssue !== 0
      ? byIssue
      : a.data.date.getTime() - b.data.date.getTime();
  })[0];

  const mostRecentDate = Math.max(
    ...seriesReadings.map((r) => r.data.date.getTime()),
  );

  items.push({
    type: "series",
    cover: getCoverPath(firstIssue.data.cover, seriesName),
    sortDate: mostRecentDate,
    slug: `${ROUTES.collections}${slugify(seriesName)}/`,
    tags: ["serie"],
    title: seriesName,
    volumes: seriesReadings.length,
  });
}

items.sort((a, b) => b.sortDate - a.sortDate);

const breadcrumbs = [
  { href: ROUTES.publishers, text: "Editoras" },
  { href: null, text: name },
];
---

<Layout title={name}>
  <section>
    <LayoutContainer>
      <Breadcrumb items={breadcrumbs} />

      <div class="publisher-hero">
        {
          logo ? (
            <figure class="publisher-logo" aria-hidden="true">
              <img src={logo} alt="" />
            </figure>
          ) : (
            <div class="publisher-initials" aria-hidden="true">
              {name.charAt(0)}
            </div>
          )
        }
        <div class="publisher-info">
          <TitlePage>{name}</TitlePage>
          {description && <TextPage>{description}</TextPage>}
          <p class="publisher-count">
            Com <strong
              >{readings.length}
              {readings.length === 1 ? "leitura" : "leituras"}</strong
            > publicadas no blog.
          </p>
        </div>
      </div>

      {
        items.length > 0 && (
          <GridRead>
            {items.map((item) =>
              item.type === "series" ? (
                <CardCollection {...item} />
              ) : (
                <CardRead {...item} />
              ),
            )}
          </GridRead>
        )
      }
    </LayoutContainer>
  </section>
</Layout>

<style lang="scss">
  .publisher-hero {
    --title-page-text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 24px;
    margin-block: 48px;
    text-align: center;

    @include container-tablet {
      --title-page-text-align: left;
      flex-direction: row;
      justify-content: flex-start;
      gap: 32px;
      margin-block: 64px;
      text-align: left;
    }
  }

  .publisher-logo {
    flex-shrink: 0;
    width: 120px;
    height: 120px;

    img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    @include container-tablet {
      width: 160px;
      height: 160px;
    }
  }

  .publisher-initials {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    border: 4px solid var(--color-grey-light-300);
    border-radius: 50%;
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--color-yellow-grey-100);
    background-color: var(--color-grey-light-200);

    @include container-tablet {
      width: 160px;
      height: 160px;
      font-size: 4.5rem;
    }
  }

  .publisher-info {
    --title-page-font-size: clamp(2rem, 3vw, 2.75rem);
    --title-page-margin-block-end: 8px;
    --title-page-margin-block-end-p: 8px;
  }

  .publisher-count {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-grey-light-1100);

    strong {
      font-weight: 700;
    }
  }
</style>
